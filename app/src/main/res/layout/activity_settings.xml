<?xml version="1.0" encoding="utf-8"?>
<!--
  Landscape layout: ~229dp tall after status bar.
  Two-column design — left col: timer controls, right col: voice toggles + buttons.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- LEFT COLUMN: title + timer settings -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Sets row -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Number of Sets"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <Button
                android:id="@+id/btnRepsMinus"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="−"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="@color/btn_secondary" />
            <TextView
                android:id="@+id/tvRepsVal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="12"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:textStyle="bold" />
            <Button
                android:id="@+id/btnRepsPlus"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="+"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="@color/btn_secondary" />
        </LinearLayout>

        <!-- Work duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Work Duration"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />
            <TextView
                android:id="@+id/tvActiveVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/accent_green" />
        </LinearLayout>
        <SeekBar
            android:id="@+id/sbActive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <!-- Rest duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rest Duration"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />
            <TextView
                android:id="@+id/tvRestVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/rest_color" />
        </LinearLayout>
        <SeekBar
            android:id="@+id/sbRest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <!-- Total time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total: "
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Warmup -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="2dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Warmup"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />
            <TextView
                android:id="@+id/tvWarmupVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#FFFF9800"
                android:layout_marginEnd="6dp" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swWarmup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
        <SeekBar
            android:id="@+id/sbWarmup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Vertical divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/btn_secondary"
        android:layout_marginEnd="16dp" />

    <!-- RIGHT COLUMN: voice toggles + buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Announcements"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Toggle row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text='Announce "Go!" each set'
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swAnnounceStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text='Announce "Rest" each rest'
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swAnnounceRest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="0dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Milestones (50%, 75%, 95%)"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swMilestones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Push buttons to bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Buttons -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textSize="14sp"
            android:paddingVertical="6dp"
            android:backgroundTint="@color/accent_green"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset to Defaults"
            android:textSize="14sp"
            android:paddingVertical="6dp"
            android:backgroundTint="@color/btn_secondary" />

    </LinearLayout>

</LinearLayout>
