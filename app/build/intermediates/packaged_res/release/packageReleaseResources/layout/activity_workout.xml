<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Workout in progress — tap anywhere to pause -->
    <RelativeLayout
        android:id="@+id/layoutWorkout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Phase + countdown centred -->
        <LinearLayout
            android:id="@+id/layoutCenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvPhase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WORK"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30"
                android:textSize="96sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvRepProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set 1 / 12"
                android:textSize="20sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Progress bar + % pinned to bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp">

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/accent_green"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvOverallPct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Tap hint top-right -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:text="Tap to pause"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

    </RelativeLayout>

    <!-- Paused overlay -->
    <LinearLayout
        android:id="@+id/layoutPaused"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="#E6000000"
        android:visibility="gone"
        android:padding="24dp">

        <!-- Left: pause title + stats -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸ Paused"
                android:textSize="32sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/tvPausedPhase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvPausedTimeLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvPausedSet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Right: action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btnContinue"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="▶  Continue Workout"
                android:textSize="18sp"
                android:paddingVertical="12dp"
                android:backgroundTint="@color/accent_green"
                android:layout_marginBottom="16dp"
                android:focusable="true" />

            <Button
                android:id="@+id/btnCancelWorkout"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="✕  Cancel Workout"
                android:textSize="16sp"
                android:paddingVertical="10dp"
                android:backgroundTint="@color/btn_danger"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- Workout complete -->
    <LinearLayout
        android:id="@+id/layoutComplete"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_dark"
        android:visibility="gone"
        android:padding="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉 Workout Complete!"
            android:textSize="40sp"
            android:textColor="@color/accent_green"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvCompleteTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="36dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDoAgain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Do Again"
                android:textSize="20sp"
                android:paddingHorizontal="36dp"
                android:paddingVertical="12dp"
                android:backgroundTint="@color/accent_green"
                android:layout_marginEnd="20dp"
                android:focusable="true" />

            <Button
                android:id="@+id/btnDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Done"
                android:textSize="20sp"
                android:paddingHorizontal="36dp"
                android:paddingVertical="12dp"
                android:backgroundTint="@color/btn_secondary"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
